{
  "manifest_version": 3,
  "name": "Veil",
  "version": "0.2.0",
  "description": "Ask anything about what you're watching — get answers without spoilers.",
  "permissions": ["storage", "sidePanel", "activeTab", "scripting", "tabs", "webNavigation"],
  "host_permissions": [
    "https://*.crunchyroll.com/*",
    "https://crunchyroll.com/*",
    "https://www.netflix.com/*",
    "https://graphql.anilist.co/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Open Veil",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.crunchyroll.com/watch/*",
        "https://crunchyroll.com/watch/*"
      ],
      "js": ["subtitle-interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": false
    },
    {
      "matches": [
        "https://*.crunchyroll.com/*",
        "https://crunchyroll.com/*",
        "https://www.crunchyroll.com/*",
        "https://www.netflix.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}

