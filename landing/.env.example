# Copy to .env.local for local Next dev (never commit .env.local)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# SHA-256 hex of the admin password (must match exactly on Vercel for production):
#   printf '%s' 'your-secret-password' | shasum -a 256
NEXT_PUBLIC_ADMIN_HASH=
